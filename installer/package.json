{
  "name": "instalar-monserrath",
  "version": "2.0.0",
  "main": "src/index.js",
  "scripts": {
    "build": "pkg src/index.js --target node18-win-x64 --output ../instalar-monserrath.exe --no-bytecode --public --public-packages \"*\""
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "scripts": ["src/index.js"],
    "options": ["no-bytecode"],
    "outputPath": ".."
  },
  "dependencies": {
    "chalk": "4.1.2",
    "inquirer": "8.2.6",
    "ora": "5.4.1"
  }
}
